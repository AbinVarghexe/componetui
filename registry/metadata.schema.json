{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Component Metadata",
  "type": "object",
  "required": ["id", "name", "version", "frameworks"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "frameworks": {
      "type": "array",
      "items": { "type": "string", "enum": ["react", "next", "vite", "remix"] },
      "minItems": 1
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "description": { "type": "string" }
  },
  "additionalProperties": false
}
